<section class="help-faq-block mb-4 rounded-lg border border-border">
    <details class="group">
        <summary class="cursor-pointer list-none px-4 py-3 text-base font-semibold text-foreground">
            $Question
        </summary>
        <div class="border-t border-border px-4 py-3 text-foreground/90 leading-relaxed">
            $Answer
        </div>
    </details>
</section>
