{
  "name": "tipbr/silverstripe-help-centre",
  "description": "Silverstripe help centre pages, block, and content population task",
  "type": "silverstripe-vendormodule",
  "license": "BSD-3-Clause",
  "require": {
    "php": "^8.3",
    "silverstripe/framework": "^6",
    "silverstripe/cms": "^6",
    "dnadesign/silverstripe-elemental": "^6.2"
  },
  "autoload": {
    "psr-4": {
      "ForwardFi\\Pages\\": "src/Pages/",
      "ForwardFi\\Blocks\\": "src/Blocks/",
      "ForwardFi\\Tasks\\": "src/Tasks/"
    }
  },
  "extra": {
    "expose": []
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
